{
  "config": {
    "policy_name": "kl-strict",
    "allow_list_bypass_scan": false,
    "scan_on_install": true,
    "max_enforcement_delay_seconds": 1
  },
  "actions": {
    "CRITICAL": {
      "runtime": "block",
      "file": "quarantine",
      "install": "block"
    },
    "HIGH": {
      "runtime": "block",
      "file": "quarantine",
      "install": "block"
    },
    "MEDIUM": {
      "runtime": "block",
      "file": "quarantine",
      "install": "block"
    },
    "LOW": {
      "runtime": "allow",
      "file": "none",
      "install": "none"
    },
    "INFO": {
      "runtime": "allow",
      "file": "none",
      "install": "none"
    }
  },
  "scanner_overrides": {
    "mcp": {
      "MEDIUM": {
        "runtime": "block",
        "file": "quarantine",
        "install": "block"
      },
      "LOW": {
        "runtime": "block",
        "file": "none",
        "install": "none"
      }
    },
    "plugin": {
      "HIGH": {
        "runtime": "block",
        "file": "quarantine",
        "install": "block"
      },
      "MEDIUM": {
        "runtime": "allow",
        "file": "none",
        "install": "none"
      }
    }
  },
  "first_party_allow_list": [
    {
      "target_type": "plugin",
      "target_name": "defenseclaw",
      "reason": "first-party DefenseClaw plugin",
      "source_path_contains": [
        ".defenseclaw",
        ".openclaw/extensions",
        ".zeptoclaw/extensions",
        ".claude/extensions",
        ".codex/extensions",
        ".codex-plugin"
      ]
    },
    {
      "target_type": "skill",
      "target_name": "codeguard",
      "reason": "first-party DefenseClaw skill",
      "source_path_contains": [
        ".defenseclaw",
        ".openclaw/workspace/skills",
        ".openclaw/skills",
        ".zeptoclaw/skills",
        ".claude/skills",
        ".codex/skills"
      ]
    }
  ],
  "severity_ranking": {
    "CRITICAL": 5,
    "HIGH": 4,
    "MEDIUM": 3,
    "LOW": 2,
    "INFO": 1
  },
  "audit": {
    "retention_days": 365,
    "log_all_actions": true,
    "log_scan_results": true
  },
  "guardrail": {
    "severity_rank": {
      "NONE": 0,
      "LOW": 1,
      "MEDIUM": 2,
      "HIGH": 3,
      "CRITICAL": 4
    },
    "block_threshold": 2,
    "alert_threshold": 1,
    "cisco_trust_level": "full",
    "hilt": {
      "enabled": false,
      "min_severity": "HIGH"
    },
    "patterns": {
      "injection": [
        "ignore previous",
        "ignore all instructions",
        "ignore above",
        "disregard previous",
        "disregard all",
        "you are now",
        "act as",
        "pretend you are",
        "bypass",
        "jailbreak",
        "do anything now",
        "dan mode"
      ],
      "secrets": [
        "sk-",
        "sk-ant-",
        "sk-proj-",
        "api_key=",
        "apikey=",
        "-----begin rsa",
        "-----begin private",
        "-----begin openssh",
        "aws_access_key",
        "aws_secret_access",
        "password=",
        "bearer ",
        "ghp_",
        "gho_",
        "github_pat_"
      ],
      "exfiltration": [
        "/etc/passwd",
        "/etc/shadow",
        "base64 -d",
        "base64 --decode",
        "exfiltrate",
        "send to my server",
        "curl http"
      ]
    },
    "severity_mappings": {
      "injection": "HIGH",
      "secrets": "MEDIUM",
      "exfiltration": "HIGH"
    }
  },
  "firewall": {
    "default_action": "deny",
    "blocked_destinations": [
      "169.254.169.254",
      "fd00:ec2::254"
    ],
    "allowed_domains": [
      "api.anthropic.com",
      "registry.npmjs.org",
      "api.github.com",
      "github.com",
      "objects.githubusercontent.com",
      "prod-telemetry.example.com",
      "10.0.0.11",
      "log-telemetry.example.com",
      "10.0.0.12",
      "your-pp-env.environment.api.powerplatform.com",
      "smba.trafficmanager.net",
      "login.botframework.com",
      "login.microsoftonline.com"
    ],
    "allowed_ports": [
      443,
      8088,
      8089
    ]
  }
}
